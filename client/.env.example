# Copy this file to .env.local and fill in the values after running cdk deploy.
# VITE_SIGNALING_URL is printed as a CloudFormation output after deployment.

# API Gateway WebSocket endpoint (from cdk deploy output: WebSocketUrl)
VITE_SIGNALING_URL=wss://xxxxxxxxxx.execute-api.us-east-1.amazonaws.com/prod

# TURN server credentials (from your chosen provider — Metered.ca or Twilio NTS)
# If omitted, only STUN is used. Direct connections will still work for most users.
VITE_TURN_URL=turn:your-turn-server.example.com:3478
VITE_TURN_USERNAME=your-turn-username
VITE_TURN_CREDENTIAL=your-turn-credential
