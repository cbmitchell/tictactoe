# Copy this file to .env.local and fill in the values after running cdk deploy.
# VITE_SIGNALING_URL and VITE_TURN_CREDENTIALS_URL are printed as CloudFormation
# outputs after deployment.

# API Gateway WebSocket endpoint (from cdk deploy output: WebSocketUrl)
VITE_SIGNALING_URL=wss://xxxxxxxxxx.execute-api.us-east-1.amazonaws.com/prod

# TURN credentials endpoint (from cdk deploy output: TurnCredentialsUrl)
# Credentials are generated server-side by the turn-credentials Lambda.
# If omitted, only STUN is used — direct connections work for most home networks
# but will fail when one peer is behind carrier-grade NAT (e.g. mobile data).
VITE_TURN_CREDENTIALS_URL=https://xxxxxxxxxx.execute-api.us-east-1.amazonaws.com/turn-credentials

# Must match the value stored in AWS Secrets Manager under 'tictactoe/connect-secret'
# This value is embedded in the client bundle at build time — it is not strong
# authentication, just a barrier against casual endpoint abuse.
VITE_CONNECT_SECRET=
